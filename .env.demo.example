# GitEcho — demo / docs-screenshot environment.
#
# This file drives `npm run docs:demo`, which seeds a fictional dataset
# into `.dev/demo/` and captures the docs screenshots. It is COMPLETELY
# isolated from your normal `.dev/` workspace.
#
# Copy this file to `.env.demo` (gitignored), then replace MASTER_KEY
# with a real 32-byte hex value:
#
#   openssl rand -hex 32
#
# The key is a throwaway — it only encrypts the fake demo secrets.

DATA_DIR=./.dev/demo/data
CONFIG_DIR=./.dev/demo/config
BACKUPS_DIR=./.dev/demo/backups

# Required: 64 hex chars (32 bytes). Generate with `openssl rand -hex 32`.
MASTER_KEY=

# Same-origin Playwright captures hit localhost:4173 (chosen to avoid
# colliding with the regular `npm run dev` on port 3000).
PUBLIC_URL=http://localhost:4173
TZ=Europe/Berlin
