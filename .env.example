# GitHub (required if backing up GitHub repos)
GITHUB_PAT=ghp_xxxxxxxxxxxx
GITHUB_PAT_EXPIRES=2026-06-01

# Azure DevOps (required if backing up Azure DevOps repos)
# AZUREDEVOPS_PAT=xxxxxxxxxxxxxxxx
# AZUREDEVOPS_PAT_EXPIRES=2026-06-01

# Backup settings
BACKUP_MODE=option1
CRON_SCHEDULE=0 2 * * *

# SMTP notifications (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASS=secret
# SMTP_FROM=gitecho@example.com
# SMTP_TO=admin@example.com
# NOTIFY_ON_SUCCESS=false
# PAT_EXPIRY_WARN_DAYS=14

# Web UI (optional but strongly recommended)
# When both UI_USER and UI_PASS are set, the web UI requires HTTP Basic Auth.
# UI_USER=admin
# UI_PASS=change-me

# Public URL(s) under which the UI is reachable. Needed when GitEcho runs
# behind a reverse proxy (Synology DSM portal, Traefik, nginx) that changes
# host/port. State-changing requests whose Origin header matches the request
# host are always accepted; any additional public URLs must be listed here
# (comma-separated).
#   Examples:
#   PUBLIC_URL=https://gitecho.example.com
#   PUBLIC_URL=https://nas.local:5000,https://gitecho.example.com
# PUBLIC_URL=

# Settings UI secret encryption key.
# Required only when storing PAT/SMTP secrets via the Settings UI.
# Generate with: openssl rand -hex 32
# MASTER_KEY=

# Azure DevOps organization (only needed if you don't set it via the UI)
# AZUREDEVOPS_ORG=myorg
