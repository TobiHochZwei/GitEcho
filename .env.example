# GitHub (required if backing up GitHub repos)
GITHUB_PAT=ghp_xxxxxxxxxxxx
GITHUB_PAT_EXPIRES=2026-06-01

# Azure DevOps (required if backing up Azure DevOps repos)
# AZUREDEVOPS_PAT=xxxxxxxxxxxxxxxx
# AZUREDEVOPS_PAT_EXPIRES=2026-06-01

# GitLab (required if backing up GitLab repos)
# GITLAB_PAT=glpat-xxxxxxxxxxxxxxxx
# GITLAB_PAT_EXPIRES=2026-06-01
# Optional — only for self-hosted GitLab instances (default: gitlab.com)
# GITLAB_HOST=gitlab.example.com

# Backup settings
BACKUP_MODE=option1
CRON_SCHEDULE=0 2 * * *

# SMTP notifications (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASS=secret
# SMTP_FROM=gitecho@example.com
# SMTP_TO=admin@example.com
# NOTIFY_ON_SUCCESS=false
# PAT_EXPIRY_WARN_DAYS=14

# Web UI
# Authentication is bootstrapped automatically: on first startup GitEcho
# seeds an "admin" account with password "admin" and forces you to change
# it on first login. Credentials are stored (bcrypt-hashed) in the
# encrypted secrets vault — no UI_USER/UI_PASS env vars are used anymore.

# Public URL(s) under which the UI is reachable. Needed when GitEcho runs
# behind a reverse proxy (Synology DSM portal, Traefik, nginx) that changes
# host/port. State-changing requests whose Origin header matches the request
# host are always accepted; any additional public URLs must be listed here
# (comma-separated).
#   Examples:
#   PUBLIC_URL=https://gitecho.example.com
#   PUBLIC_URL=https://nas.local:5000,https://gitecho.example.com
# Set to `*` to accept all origins and disable the CSRF origin check
# entirely. Not recommended — any website the logged-in user visits can
# trigger state-changing requests against GitEcho.
#   PUBLIC_URL=*
# PUBLIC_URL=

# Secret encryption key — REQUIRED.
# Protects the admin password hash, provider PATs and SMTP credentials.
# The container refuses to start without it. Generate with:
#   openssl rand -hex 32
MASTER_KEY=

# Azure DevOps organization (only needed if you don't set it via the UI)
# AZUREDEVOPS_ORG=myorg
