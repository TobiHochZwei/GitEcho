---
interface Props {
  title?: string;
  icon?: string;
  variant?: 'default' | 'primary' | 'success' | 'danger' | 'warning' | 'info';
  bodyClass?: string;
  noBody?: boolean;
}
const { title, icon, variant = 'default', bodyClass = '', noBody = false } = Astro.props;
const headerClass = variant === 'default' ? '' : `text-bg-${variant}`;
---
<div class="card shadow-sm mb-3">
  {title && (
    <div class={`card-header d-flex justify-content-between align-items-center gap-2 ${headerClass}`}>
      <h5 class="card-title mb-0">
        {icon && <i class={`bi ${icon} me-2`}></i>}
        {title}
      </h5>
      <div class="ms-auto">
        <slot name="header-actions" />
      </div>
    </div>
  )}
  {noBody ? <slot /> : <div class={`card-body ${bodyClass}`}><slot /></div>}
</div>
