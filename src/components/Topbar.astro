---
interface Crumb { label: string; href?: string; }
interface Props {
  title?: string;
  breadcrumbs?: Crumb[];
  user?: string | null;
}
const { title = '', breadcrumbs = [], user = null } = Astro.props;
---
<nav class="app-header navbar navbar-expand bg-body border-bottom shadow-sm sticky-top">
  <div class="container-fluid">
    <ul class="navbar-nav">
      <li class="nav-item">
        <button class="btn btn-link nav-link" type="button" data-lte-toggle="sidebar" aria-label="Toggle sidebar">
          <i class="bi bi-list fs-4"></i>
        </button>
      </li>
    </ul>

    <div class="ms-2 d-none d-md-flex flex-column">
      {title && <span class="fw-semibold">{title}</span>}
      {breadcrumbs.length > 0 && (
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-0 small">
            {breadcrumbs.map((c, i) => (
              <li class={`breadcrumb-item ${i === breadcrumbs.length - 1 ? 'active' : ''}`}>
                {c.href && i !== breadcrumbs.length - 1 ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
              </li>
            ))}
          </ol>
        </nav>
      )}
    </div>

    <ul class="navbar-nav ms-auto align-items-center">
      <li class="nav-item">
        <button id="theme-toggle" type="button" class="btn btn-link nav-link" aria-label="Toggle dark mode" title="Toggle theme">
          <i id="theme-toggle-icon" class="bi bi-sun-fill fs-5"></i>
        </button>
      </li>
      {user && (
        <li class="nav-item dropdown">
          <button class="btn btn-link nav-link dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-person-circle fs-5 me-1"></i>
            <span class="d-none d-sm-inline">{user}</span>
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><span class="dropdown-item-text small text-secondary">Signed in as <strong>{user}</strong></span></li>
            <li><hr class="dropdown-divider" /></li>
            <li>
              <a class="dropdown-item" href="/api/logout" id="logout-link">
                <i class="bi bi-box-arrow-right me-1"></i>Sign out
              </a>
            </li>
          </ul>
        </li>
      )}
    </ul>
  </div>
</nav>
