---
import 'bootstrap/dist/css/bootstrap.min.css';
import 'bootstrap-icons/font/bootstrap-icons.css';
import 'admin-lte/dist/css/adminlte.min.css';

import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import Toasts from '../components/Toasts.astro';

interface Crumb { label: string; href?: string; }
interface Props {
  title: string;
  active?: 'dashboard' | 'repos' | 'runs' | 'logs' | 'settings';
  settingsActive?: 'index' | 'general' | 'providers' | 'repos' | 'smtp' | null;
  breadcrumbs?: Crumb[];
  pageTitle?: string;
  /** Visual health hint: 'success' (green border) or 'danger' (red border). */
  health?: 'success' | 'danger' | null;
  backupMode?: string;
}
const {
  title,
  active,
  settingsActive = null,
  breadcrumbs = [],
  pageTitle = '',
  health = null,
  backupMode = '',
} = Astro.props;

const user = process.env.UI_USER || null;
---
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <title>{title}</title>
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
  <div class="app-wrapper d-flex">
    <Sidebar active={active} settingsActive={settingsActive} backupMode={backupMode} />

    <div class="app-main flex-grow-1 d-flex flex-column min-vh-100" style="min-width:0;">
      <Topbar title={pageTitle} breadcrumbs={breadcrumbs} user={user} />

      {health && (
        <div class={`health-accent health-${health}`}>
          {health === 'success'
            ? <span><i class="bi bi-check-circle-fill me-1"></i>Backups up to date</span>
            : <span><i class="bi bi-exclamation-triangle-fill me-1"></i>No successful backup in the last 24 hours</span>}
        </div>
      )}

      <main class="app-content p-3 p-md-4 flex-grow-1">
        <slot />
      </main>

      <footer class="app-footer text-center text-secondary small py-3 border-top">
        <span>GitEcho — repository backups for GitHub, Azure DevOps &amp; GitLab</span>
      </footer>
    </div>
  </div>

  <Toasts />

  <style is:global>
    html, body { height: 100%; }
    body { overflow-x: hidden; }
    .app-wrapper { width: 100%; }
    .app-main { background-color: var(--bs-body-bg); }
    .health-accent {
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
      font-weight: 500;
      border-bottom: 3px solid;
    }
    .health-success {
      background: rgba(25, 135, 84, 0.1);
      color: var(--bs-success-text-emphasis);
      border-color: var(--bs-success);
    }
    .health-danger {
      background: rgba(220, 53, 69, 0.12);
      color: var(--bs-danger-text-emphasis);
      border-color: var(--bs-danger);
    }
    [data-bs-theme="dark"] .health-success { background: rgba(25, 135, 84, 0.18); }
    [data-bs-theme="dark"] .health-danger { background: rgba(220, 53, 69, 0.2); }

    /* Better defaults */
    .table > :not(caption) > * > * { vertical-align: middle; }
    pre code { color: inherit; }
    code { color: var(--bs-pink); background: var(--bs-tertiary-bg); padding: 0.1rem 0.35rem; border-radius: 3px; }
    pre code { background: transparent; padding: 0; }
  </style>

  <script>
    import 'bootstrap/dist/js/bootstrap.bundle.min.js';
    import '../scripts/theme.ts';
    import '../scripts/sidebar.ts';
    import '../scripts/toasts.ts';
  </script>
</body>
</html>
