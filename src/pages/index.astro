---
import Layout from '../layouts/Layout.astro';
import SmallBox from '../components/SmallBox.astro';
import Card from '../components/Card.astro';
import { loadConfig } from '../lib/config.js';
import { initDatabase, getBackupRuns } from '../lib/database.js';
import {
  getExtendedStats,
  getStorageUsage,
  getRunHistory,
  formatBytes,
  formatAge,
  daysUntil,
  type ExtendedStats,
  type StorageUsage,
  type RunHistoryPoint,
} from '../lib/stats.js';
import { humanizeCron } from '../lib/cron-humanize.js';

let stats: ExtendedStats;
let recentRuns: any[] = [];
let history: RunHistoryPoint[] = [];
let storage: StorageUsage = { totalBytes: 0, byProvider: {}, computedAt: '' };
let config: any;
let loadError: string | null = null;
try {
  config = loadConfig();
  initDatabase(config.dataDir);
  stats = getExtendedStats();
  recentRuns = getBackupRuns(5);
  history = getRunHistory(30);
  try {
    // Never walk the FS from the SSR path — the worker refreshes this
    // cache after every backup run and the user can press "Recompute"
    // to force a fresh walk. If no cache exists yet we get zeros and a
    // blank `computedAt`, which the UI renders as "not computed yet".
    storage = getStorageUsage(config.backupsDir, { maxAgeMs: Infinity });
  } catch (e) {
    storage = { totalBytes: 0, byProvider: {}, computedAt: '' };
  }
} catch (e) {
  loadError = (e as Error).message;
  stats = {
    totalRepos: 0,
    lastBackupAt: null,
    lastBackupAgeSeconds: null,
    lastRunStatus: null,
    hadRecentBackup: false,
    successRate30: null,
    failedRuns7d: 0,
    unavailableCount: 0,
  };
  config = { backupMode: 'option1', cronSchedule: '0 2 * * *', cronEnabled: true, github: null, azureDevOps: null, gitlab: null };
}

const health = stats.hadRecentBackup ? 'success' : 'danger';

const modeLabel =
  config.backupMode === 'option1'
    ? 'Git Pull (option1)'
    : config.backupMode === 'option3'
      ? 'Mirror + ZIP (option3)'
      : 'ZIP Snapshots (option2)';

const cronHuman = humanizeCron(config.cronSchedule);

function patBadge(days: number | null): { variant: string; label: string } {
  if (days === null) return { variant: 'secondary', label: 'No expiry set' };
  if (days < 0) return { variant: 'danger', label: `Expired ${-days}d ago` };
  if (days < 7) return { variant: 'danger', label: `Expires in ${days}d` };
  if (days < 30) return { variant: 'warning', label: `Expires in ${days}d` };
  return { variant: 'success', label: `${days}d remaining` };
}

const ghDays = daysUntil(config.github?.patExpires);
const adoDays = daysUntil(config.azureDevOps?.patExpires);
const glDays = daysUntil(config.gitlab?.patExpires);
const ghBadge = patBadge(ghDays);
const adoBadge = patBadge(adoDays);
const glBadge = patBadge(glDays);

const historyLabels = JSON.stringify(history.map((h) => h.id));
const historySuccess = JSON.stringify(history.map((h) => h.success));
const historyFailed = JSON.stringify(history.map((h) => h.failed));
---
<Layout
  title="GitEcho — Dashboard"
  active="dashboard"
  pageTitle="Dashboard"
  breadcrumbs={[{ label: 'Home' }]}
  health={health}
  backupMode={modeLabel}
>
  {loadError && (
    <div class="alert alert-warning d-flex align-items-center" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      <div>Failed to load dashboard data: <code>{loadError}</code></div>
    </div>
  )}

  {stats.unavailableCount > 0 && (
    <div class="alert alert-warning d-flex align-items-center" role="alert">
      <i class="bi bi-cloud-slash-fill me-2 fs-4"></i>
      <div class="flex-grow-1">
        <strong>{stats.unavailableCount}</strong> repositor{stats.unavailableCount === 1 ? 'y is' : 'ies are'} unreachable upstream.
        They were skipped during the last backup; existing local copies are preserved.
      </div>
      <a href="/repos" class="btn btn-sm btn-outline-warning ms-2">Review</a>
    </div>
  )}

  <!-- KPI tiles -->
  <div class="row">
    <div class="col-12 col-sm-6 col-md-3">
      <SmallBox value={stats.totalRepos} label="Total repositories" icon="bi-git" variant="primary" href="/repos" footer="Manage repos" />
    </div>
    <div class="col-12 col-sm-6 col-md-3">
      <SmallBox value={formatAge(stats.lastBackupAgeSeconds)} label="Last backup" icon="bi-clock-history" variant={stats.hadRecentBackup ? 'success' : 'danger'} href="/runs" footer="See runs" />
    </div>
    <div class="col-12 col-sm-6 col-md-3">
      <SmallBox value={stats.successRate30 === null ? '—' : `${stats.successRate30}%`} label="Success rate (30 runs)" icon="bi-check2-circle" variant="info" href="/runs" footer="Run history" />
    </div>
    <div class="col-12 col-sm-6 col-md-3">
      <SmallBox value={stats.unavailableCount} label="Unavailable upstream" icon="bi-cloud-slash" variant={stats.unavailableCount > 0 ? 'danger' : 'secondary'} href="/repos" footer="Review repos" />
    </div>
  </div>

  <!-- Schedule info -->
  <div class="row">
    <div class="col-12">
      {config.cronEnabled === false ? (
        <div class="alert alert-warning d-flex align-items-center mb-3" role="alert">
          <i class="bi bi-pause-circle-fill me-2 fs-4"></i>
          <div class="flex-grow-1">
            <strong>Automatic backups are disabled.</strong>
            Only manual runs via <em>Trigger Backup</em> will execute
            <span class="ms-1 text-secondary small">(schedule: <code>{config.cronSchedule}</code>)</span>.
          </div>
          <a href="/settings/general" class="btn btn-sm btn-outline-warning ms-2">Change</a>
        </div>
      ) : (
        <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
          <i class="bi bi-clock-history me-2 fs-4"></i>
          <div class="flex-grow-1">
            <strong>Backup schedule:</strong> {cronHuman}
            <span class="ms-2 text-secondary small">(<code>{config.cronSchedule}</code>)</span>
          </div>
          <a href="/settings/general" class="btn btn-sm btn-outline-info ms-2">Change</a>
        </div>
      )}
    </div>
  </div>

  <!-- Provider cards -->
  <div class="row">
    <div class="col-12 col-lg-4">
      <Card title="GitHub" icon="bi-github">
        {config.github ? (
          <>
            <div class="mb-2">
              <span class="badge text-bg-success me-2"><i class="bi bi-check-circle me-1"></i>Configured</span>
              <span class={`badge text-bg-${ghBadge.variant}`}><i class="bi bi-key me-1"></i>{ghBadge.label}</span>
            </div>
            <p class="mb-1 text-secondary small">PAT expires: <strong>{config.github.patExpires?.toISOString().slice(0, 10) ?? '—'}</strong></p>
            <p class="mb-1 text-secondary small">Auto-discover: <strong>{config.github.autoDiscover === false ? 'off' : 'on'}</strong></p>
            <button class="btn btn-sm btn-outline-primary mt-2" data-action="test-github"><i class="bi bi-plug me-1"></i>Test connection</button>
          </>
        ) : (
          <>
            <span class="badge text-bg-secondary"><i class="bi bi-x-circle me-1"></i>Not configured</span>
            <p class="mt-2 mb-0"><a href="/settings/providers" class="btn btn-sm btn-primary"><i class="bi bi-gear me-1"></i>Configure</a></p>
          </>
        )}
      </Card>
    </div>
    <div class="col-12 col-lg-4">
      <Card title="Azure DevOps" icon="bi-microsoft">
        {config.azureDevOps ? (
          <>
            <div class="mb-2">
              <span class="badge text-bg-success me-2"><i class="bi bi-check-circle me-1"></i>Configured</span>
              <span class={`badge text-bg-${adoBadge.variant}`}><i class="bi bi-key me-1"></i>{adoBadge.label}</span>
            </div>
            <p class="mb-1 text-secondary small">PAT expires: <strong>{config.azureDevOps.patExpires?.toISOString().slice(0, 10) ?? '—'}</strong></p>
            <p class="mb-1 text-secondary small">Org: <strong>{config.azureDevOps.org ?? '—'}</strong></p>
            <button class="btn btn-sm btn-outline-primary mt-2" data-action="test-azuredevops"><i class="bi bi-plug me-1"></i>Test connection</button>
          </>
        ) : (
          <>
            <span class="badge text-bg-secondary"><i class="bi bi-x-circle me-1"></i>Not configured</span>
            <p class="mt-2 mb-0"><a href="/settings/providers" class="btn btn-sm btn-primary"><i class="bi bi-gear me-1"></i>Configure</a></p>
          </>
        )}
      </Card>
    </div>
    <div class="col-12 col-lg-4">
      <Card title="GitLab" icon="bi-gitlab">
        {config.gitlab ? (
          <>
            <div class="mb-2">
              <span class="badge text-bg-success me-2"><i class="bi bi-check-circle me-1"></i>Configured</span>
              <span class={`badge text-bg-${glBadge.variant}`}><i class="bi bi-key me-1"></i>{glBadge.label}</span>
            </div>
            <p class="mb-1 text-secondary small">PAT expires: <strong>{config.gitlab.patExpires?.toISOString().slice(0, 10) ?? '—'}</strong></p>
            <p class="mb-1 text-secondary small">Host: <strong>{config.gitlab.host ?? 'gitlab.com'}</strong></p>
            <button class="btn btn-sm btn-outline-primary mt-2" data-action="test-gitlab"><i class="bi bi-plug me-1"></i>Test connection</button>
          </>
        ) : (
          <>
            <span class="badge text-bg-secondary"><i class="bi bi-x-circle me-1"></i>Not configured</span>
            <p class="mt-2 mb-0"><a href="/settings/providers" class="btn btn-sm btn-primary"><i class="bi bi-gear me-1"></i>Configure</a></p>
          </>
        )}
      </Card>
    </div>
  </div>

  <!-- Storage + Sparkline -->
  <div class="row">
    <div class="col-12 col-lg-4">
      <Card title="Storage usage" icon="bi-hdd">
        <h2 class="display-6 fw-semibold mb-1" id="storage-total">{formatBytes(storage.totalBytes)}</h2>
        <p class="text-secondary mb-2 small">
          Total under <code>{config.backupsDir}</code>
          <br />
          <span id="storage-age">
            {storage.computedAt
              ? <>computed {formatAge(Math.max(0, Math.round((Date.now() - new Date(storage.computedAt).getTime()) / 1000)))}</>
              : <em>not computed yet — run a backup or press Recompute</em>}
          </span>
        </p>
        <ul class="list-unstyled mb-2 small" id="storage-breakdown">
          {Object.entries(storage.byProvider).map(([p, b]) => (
            <li class="d-flex justify-content-between border-bottom py-1">
              <span class="text-capitalize">{p}</span>
              <span class="font-monospace">{formatBytes(b as number)}</span>
            </li>
          ))}
        </ul>
        <button class="btn btn-sm btn-outline-secondary" id="refresh-storage">
          <i class="bi bi-arrow-clockwise me-1"></i>Recompute
        </button>
      </Card>
    </div>
    <div class="col-12 col-lg-8">
      <Card title="Backup health (last 30 runs)" icon="bi-graph-up">
        {history.length === 0 ? (
          <p class="text-secondary mb-0">No backup runs yet.</p>
        ) : (
          <div style="height: 220px;">
            <canvas
              id="history-chart"
              data-labels={historyLabels}
              data-success={historySuccess}
              data-failed={historyFailed}
            ></canvas>
          </div>
        )}
      </Card>
    </div>
  </div>

  <!-- Quick actions -->
  <div class="row">
    <div class="col-12">
      <Card title="Quick actions" icon="bi-lightning-charge">
        <div class="d-flex flex-wrap gap-2">
          <button id="run-backup-btn" class="btn btn-primary">
            <i class="bi bi-play-circle me-1"></i>Run backup now
          </button>
          <button class="btn btn-outline-secondary" data-action="test-github" disabled={!config.github}>
            <i class="bi bi-github me-1"></i>Test GitHub
          </button>
          <button class="btn btn-outline-secondary" data-action="test-azuredevops" disabled={!config.azureDevOps}>
            <i class="bi bi-microsoft me-1"></i>Test Azure DevOps
          </button>
          <button class="btn btn-outline-secondary" data-action="test-gitlab" disabled={!config.gitlab}>
            <i class="bi bi-gitlab me-1"></i>Test GitLab
          </button>
          <button class="btn btn-outline-secondary" data-action="test-smtp">
            <i class="bi bi-envelope me-1"></i>Send test email
          </button>
          <span id="backup-status" class="ms-auto text-secondary small align-self-center"></span>
        </div>
      </Card>
    </div>
  </div>

  <!-- Recent runs -->
  <Card title={`Recent backup runs`} icon="bi-list-task">
    {recentRuns.length === 0 ? (
      <p class="text-secondary mb-0">No backup runs yet.</p>
    ) : (
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>#</th>
              <th>Started</th>
              <th>Status</th>
              <th class="text-end">Repos</th>
              <th class="text-end">Success</th>
              <th class="text-end">Failed</th>
              <th>Mode</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {recentRuns.map((r: any) => (
              <tr>
                <td class="font-monospace">#{r.id}</td>
                <td>{new Date(r.started_at).toLocaleString()}</td>
                <td>
                  <span class={`badge text-bg-${r.status === 'success' ? 'success' : r.status === 'failed' ? 'danger' : r.status === 'running' ? 'info' : 'warning'}`}>
                    {r.status}
                  </span>
                </td>
                <td class="text-end">{r.repos_total}</td>
                <td class="text-end text-success">{r.repos_success}</td>
                <td class="text-end text-danger">{r.repos_failed}</td>
                <td><code>{r.backup_mode}</code></td>
                <td><a class="btn btn-sm btn-outline-primary" href={`/runs/${r.id}`}>Details</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </Card>
</Layout>

<script>
  // Render chart. Using a regular (non-`define:vars`) script so Vite bundles
  // the `chart.js/auto` import — inline scripts can't resolve bare specifiers.
  import Chart from 'chart.js/auto';

  const canvas = document.getElementById('history-chart') as HTMLCanvasElement | null;
  if (canvas) {
    const labels = JSON.parse(canvas.dataset.labels || '[]').map((id: number) => `#${id}`);
    const success = JSON.parse(canvas.dataset.success || '[]');
    const failed = JSON.parse(canvas.dataset.failed || '[]');
    new Chart(canvas, {
      type: 'bar',
      data: {
        labels,
        datasets: [
          { label: 'Success', data: success, backgroundColor: 'rgba(25,135,84,0.7)', stack: 's' },
          { label: 'Failed', data: failed, backgroundColor: 'rgba(220,53,69,0.7)', stack: 's' },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: { x: { stacked: true }, y: { stacked: true, beginAtZero: true, ticks: { precision: 0 } } },
        plugins: { legend: { position: 'bottom' } },
      },
    });
  }
</script>

<script>
  import { toast } from '../scripts/toasts.ts';
  import { formatBytes } from '../scripts/format.ts';

  // Run backup button + polling
  const runBtn = document.getElementById('run-backup-btn') as HTMLButtonElement | null;
  const statusEl = document.getElementById('backup-status');

  async function refreshStatus() {
    try {
      const res = await fetch('/api/backup/trigger');
      const j = await res.json();
      if (j.running) {
        if (statusEl) statusEl.textContent = `Running (pid ${j.lock?.pid ?? '?'})`;
        if (runBtn) runBtn.disabled = true;
      } else {
        if (statusEl) statusEl.textContent = 'No backup running';
        if (runBtn) runBtn.disabled = false;
      }
    } catch {
      // ignore
    }
  }

  runBtn?.addEventListener('click', async () => {
    runBtn.disabled = true;
    try {
      const res = await fetch('/api/backup/trigger', { method: 'POST' });
      const j = await res.json();
      if (res.ok) {
        toast('Backup started', 'success');
      } else {
        toast(j.error || 'Failed to start backup', 'danger');
      }
    } catch (e) {
      toast('Network error: ' + (e as Error).message, 'danger');
    }
    refreshStatus();
  });

  document.querySelectorAll('[data-action="test-github"]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      toast('Testing GitHub connection…', 'info');
      const res = await fetch('/api/test/github', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
      const j = await res.json();
      toast(j.message || j.error || (res.ok ? 'OK' : 'Failed'), res.ok ? 'success' : 'danger');
    });
  });

  document.querySelectorAll('[data-action="test-azuredevops"]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      toast('Testing Azure DevOps connection…', 'info');
      const res = await fetch('/api/test/azuredevops', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
      const j = await res.json();
      toast(j.message || j.error || (res.ok ? 'OK' : 'Failed'), res.ok ? 'success' : 'danger');
    });
  });

  document.querySelectorAll('[data-action="test-gitlab"]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      toast('Testing GitLab connection…', 'info');
      const res = await fetch('/api/test/gitlab', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
      const j = await res.json();
      toast(j.message || j.error || (res.ok ? 'OK' : 'Failed'), res.ok ? 'success' : 'danger');
    });
  });

  document.querySelectorAll('[data-action="test-smtp"]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      toast('Sending test email…', 'info');
      const res = await fetch('/api/test/smtp', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
      const j = await res.json();
      toast(j.message || j.error || (res.ok ? 'OK' : 'Failed'), res.ok ? 'success' : 'danger');
    });
  });

  document.getElementById('refresh-storage')?.addEventListener('click', async () => {
    toast('Recomputing storage usage…', 'info');
    const res = await fetch('/api/storage?force=1');
    const j = await res.json();
    if (!res.ok) {
      toast(j.error || 'Failed', 'danger');
      return;
    }
    const totalEl = document.getElementById('storage-total');
    if (totalEl) totalEl.textContent = formatBytes(j.totalBytes);
    const list = document.getElementById('storage-breakdown');
    if (list) {
      list.innerHTML = Object.entries(j.byProvider as Record<string, number>)
        .map(([p, b]) => `<li class="d-flex justify-content-between border-bottom py-1"><span class="text-capitalize">${p}</span><span class="font-monospace">${formatBytes(b)}</span></li>`)
        .join('');
    }
    const ageEl = document.getElementById('storage-age');
    if (ageEl) ageEl.textContent = 'computed just now';
    toast('Storage usage updated', 'success');
  });

  refreshStatus();
  setInterval(refreshStatus, 5000);
</script>
