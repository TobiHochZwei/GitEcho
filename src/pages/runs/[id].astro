---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { loadConfig } from '../../lib/config.js';
import { initDatabase, getBackupItems, getBackupRuns, getRepository } from '../../lib/database.js';

const cfg = loadConfig();
initDatabase(cfg.dataDir);

const id = Number(Astro.params.id);
let run: any = null;
let items: Array<any> = [];
if (Number.isFinite(id) && id > 0) {
  run = getBackupRuns(1000).find((r) => r.id === id) ?? null;
  if (run) {
    items = getBackupItems(id).map((it) => ({
      ...it,
      repo: getRepository(it.repository_id) ?? null,
    }));
  }
}

function statusVariant(s: string): string {
  switch (s) {
    case 'success': return 'success';
    case 'failed': return 'danger';
    case 'running': return 'info';
    case 'partial': return 'warning';
    case 'partial_failure': return 'warning';
    case 'unavailable': return 'warning';
    case 'cancelled': return 'secondary';
    case 'skipped': return 'secondary';
    default: return 'secondary';
  }
}

function duration(start: string | null, end: string | null): string {
  if (!start || !end) return '—';
  const ms = new Date(end).getTime() - new Date(start).getTime();
  if (ms < 1000) return `${ms} ms`;
  const s = Math.round(ms / 1000);
  if (s < 60) return `${s} s`;
  const m = Math.floor(s / 60);
  return `${m}m ${s % 60}s`;
}
---
<Layout
  title={`GitEcho — Run #${id}`}
  active="runs"
  pageTitle={`Run #${id}`}
  breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Backup Runs', href: '/runs' }, { label: `#${id}` }]}
>
  {!run ? (
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>Run #{id} not found.</div>
  ) : (
    <>
      <Card>
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
          <div>
            <h3 class="mb-1">Run #{run.id}
              <span class={`badge text-bg-${statusVariant(run.status)} ms-2`}>{run.status}</span>
            </h3>
            <p class="text-secondary small mb-0">
              <i class="bi bi-clock me-1"></i>Started {new Date(run.started_at).toLocaleString()}
              {run.completed_at && <> · completed {new Date(run.completed_at).toLocaleString()}</>}
              · duration <strong>{duration(run.started_at, run.completed_at)}</strong>
            </p>
          </div>
          <div class="d-flex gap-3 small">
            <div><div class="text-secondary">Mode</div><div class="fw-semibold"><code>{run.backup_mode}</code></div></div>
            <div><div class="text-secondary">Total</div><div class="fw-semibold">{run.repos_total}</div></div>
            <div><div class="text-secondary">Success</div><div class="fw-semibold text-success">{run.repos_success}</div></div>
            <div><div class="text-secondary">Failed</div><div class="fw-semibold text-danger">{run.repos_failed}</div></div>
            <div><div class="text-secondary">Unavailable</div><div class="fw-semibold text-warning">{run.repos_unavailable ?? 0}</div></div>
            <div><div class="text-secondary">Skipped</div><div class="fw-semibold text-secondary">{run.repos_skipped ?? 0}</div></div>
          </div>
        </div>
        {run.error_summary && (
          <div class="alert alert-danger mt-3 mb-0">
            <strong><i class="bi bi-exclamation-circle me-1"></i>Errors</strong>
            <pre class="mb-0 mt-2 small" style="white-space: pre-wrap;">{run.error_summary}</pre>
          </div>
        )}
        {run.status === 'running' && (
          <div class="alert alert-warning mt-3 mb-0">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
              <div class="flex-grow-1">
                <strong><i class="bi bi-stop-circle me-1"></i>Cancel this run</strong>
                <div class="small mt-1 mb-0">
                  {run.cancellation_requested === 1 ? (
                    <>
                      Cancellation has been requested. GitEcho is finishing the currently
                      running repository and will mark the run as <code>cancelled</code>
                      afterwards. Remaining repositories will be skipped.
                    </>
                  ) : (
                    <>
                      The currently running repository is always finished before the run
                      stops — this avoids half-written archives, corrupted mirror clones
                      or orphaned temp files. All remaining repositories are then skipped
                      and the run is marked as <code>cancelled</code>. The next scheduled
                      backup cycle still runs normally.
                    </>
                  )}
                </div>
              </div>
              <button
                type="button"
                class="btn btn-outline-warning js-cancel-run"
                data-run-id={run.id}
                disabled={run.cancellation_requested === 1}
              >
                {run.cancellation_requested === 1 ? (
                  <><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Cancellation pending</>
                ) : (
                  <><i class="bi bi-stop-circle me-1"></i>Cancel run</>
                )}
              </button>
            </div>
          </div>
        )}
      </Card>

      <Card title={`Per-repository results (${items.length})`} icon="bi-list-task">
        {items.length === 0 ? (
          <p class="text-secondary mb-0">No per-repository entries.</p>
        ) : (
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>Repository</th>
                  <th>Status</th>
                  <th>Duration</th>
                  <th>Details</th>
                </tr>
              </thead>
              <tbody>
                {items.map((it: any) => (
                  <tr>
                    <td>
                      {it.repo
                        ? <a href={`/settings/repos/${it.repo.id}`} class="text-decoration-none"><span class="text-secondary">{it.repo.provider}/</span><strong>{it.repo.owner}/{it.repo.name}</strong></a>
                        : <code>#{it.repository_id}</code>}
                    </td>
                    <td><span class={`badge text-bg-${statusVariant(it.status)}`}>{it.status}</span></td>
                    <td class="small text-secondary">{duration(it.started_at, it.completed_at)}</td>
                    <td class="small">
                      {it.error && <div class="text-danger"><i class="bi bi-exclamation-circle me-1"></i>{it.error}</div>}
                      {it.checksum && <div class="font-monospace text-secondary" title={it.checksum}>sha256: {it.checksum.slice(0, 16)}…</div>}
                      {it.zip_path && <div class="text-secondary"><i class="bi bi-file-earmark-zip me-1"></i>{it.zip_path}</div>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </Card>
    </>
  )}
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.js-cancel-run').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.runId;
      if (!id) return;
      const confirmMsg =
        `Cancel backup run #${id}?\n\n` +
        `The currently running repository will finish normally (no half-written ` +
        `archives). All remaining repositories will be skipped and the run will ` +
        `be marked as "cancelled". The next scheduled backup cycle still runs.`;
      if (!confirm(confirmMsg)) return;
      btn.disabled = true;
      try {
        const res = await fetch(`/api/runs/${id}/cancel`, { method: 'POST' });
        const body = await res.json().catch(() => ({}));
        if (!res.ok || body.ok === false) {
          alert(body.error ?? `Failed to cancel run (HTTP ${res.status}).`);
          btn.disabled = false;
          return;
        }
        // Reload so the UI reflects the pending-cancellation state and
        // eventually the final `cancelled` status once the engine stops.
        window.location.reload();
      } catch (err) {
        alert(`Failed to cancel run: ${(err as Error).message}`);
        btn.disabled = false;
      }
    });
  });
</script>
