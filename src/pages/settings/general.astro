---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { getConfig } from '../../lib/config.js';
import { humanizeCron } from '../../lib/cron-humanize.js';

const cfg = getConfig();
const cronHuman = humanizeCron(cfg.cronSchedule);

// Parse PUBLIC_URL — used by the CSRF origin check in middleware.ts to accept
// state-changing requests coming through a reverse proxy / different port.
const publicUrlRaw = process.env.PUBLIC_URL ?? '';
const publicUrls: { value: string; valid: boolean; normalized: string | null }[] = publicUrlRaw
  .split(',')
  .map((s) => s.trim())
  .filter((s) => s.length > 0)
  .map((value) => {
    try {
      const u = new URL(value);
      return { value, valid: true, normalized: `${u.protocol}//${u.host}` };
    } catch {
      return { value, valid: false, normalized: null };
    }
  });

// Container timezone. Node picks up the TZ env var natively — we also show
// the effective resolved name (via Intl) and the current server time so users
// can verify their setting took effect.
const tzEnv = process.env.TZ ?? '';
const tzResolved = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
const serverTimeNow = new Date().toLocaleString('en-GB', {
  timeZone: tzResolved,
  hour12: false,
  dateStyle: 'medium',
  timeStyle: 'long',
});
---
<Layout
  title="GitEcho — Settings · General"
  active="settings"
  settingsActive="general"
  pageTitle="General"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Settings', href: '/settings' },
    { label: 'General' },
  ]}
>
  <div class="row">
    <div class="col-12 col-lg-8">
      <Card title="Backup configuration" icon="bi-sliders">
        <form id="general-form">
          <div class="mb-3">
            <label class="form-label fw-semibold" for="backupMode">Backup mode</label>
            <select id="backupMode" name="backupMode" class="form-select">
              <option value="option1" selected={cfg.backupMode === 'option1'}>option1 — git pull (history protected)</option>
              <option value="option2" selected={cfg.backupMode === 'option2'}>option2 — ZIP snapshots</option>
              <option value="option3" selected={cfg.backupMode === 'option3'}>option3 — mirror clone + ZIP snapshots (strongest revision safety)</option>
            </select>
            <div class="form-text">Affects how repositories are cloned and stored.</div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold" for="cronSchedule">Cron schedule</label>
            <input id="cronSchedule" name="cronSchedule" class="form-control font-monospace" value={cfg.cronSchedule} />
            <div class="form-text">
              <span id="cronHuman" class="fw-semibold text-info"><i class="bi bi-clock me-1"></i>{cronHuman}</span>
              <br />5 or 6 fields. Restart the worker container for this to take effect.
            </div>
          </div>
          <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button>
        </form>
      </Card>
    </div>

    <div class="col-12 col-lg-8">
      <Card title="Container timezone (TZ)" icon="bi-globe2">
        <p class="small text-secondary mb-2">
          Controls log timestamps, cron schedules and <code>Date</code> values
          inside the app. Configure via the <code>TZ</code> environment
          variable (IANA name, e.g. <code>Europe/Berlin</code>). Restart the
          container to apply changes.
        </p>
        <ul class="list-group">
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span><code>TZ</code> env var</span>
            {tzEnv ? (
              <code>{tzEnv}</code>
            ) : (
              <span class="badge text-bg-secondary">not set (defaults to UTC)</span>
            )}
          </li>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>Resolved timezone</span>
            <span class="badge text-bg-info"><i class="bi bi-geo-alt me-1"></i>{tzResolved}</span>
          </li>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>Current server time</span>
            <span class="font-monospace small">{serverTimeNow}</span>
          </li>
        </ul>
      </Card>
    </div>

    <div class="col-12 col-lg-8">
      <Card title="Allowed origins (PUBLIC_URL)" icon="bi-shield-lock">
        <p class="small text-secondary mb-2">
          Cross-site POST/PUT/DELETE requests are rejected unless the browser's
          <code>Origin</code> matches one of these URLs. Configure via the
          <code>PUBLIC_URL</code> environment variable (comma-separated).
          Restart the container to apply changes.
        </p>
        {publicUrls.length === 0 ? (
          <div class="alert alert-warning mb-0 py-2 small" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>
            <code>PUBLIC_URL</code> is not set. Same-origin requests still work,
            but any reverse-proxy / different-port access will be rejected with 403.
          </div>
        ) : (
          <ul class="list-group">
            {publicUrls.map((entry) => (
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <code class="text-break">{entry.value}</code>
                {entry.valid ? (
                  <span class="badge text-bg-success"><i class="bi bi-check-circle me-1"></i>{entry.normalized}</span>
                ) : (
                  <span class="badge text-bg-danger"><i class="bi bi-x-circle me-1"></i>Invalid URL</span>
                )}
              </li>
            ))}
          </ul>
        )}
      </Card>
    </div>

  </div>
</Layout>

<script>
  import { toast } from '../../scripts/toasts.ts';
  import cronstrue from 'cronstrue';

  const form = document.getElementById('general-form') as HTMLFormElement | null;
  const cronInput = document.getElementById('cronSchedule') as HTMLInputElement | null;
  const cronHuman = document.getElementById('cronHuman');

  function updateCronHuman(): void {
    if (!cronInput || !cronHuman) return;
    const v = cronInput.value.trim();
    let text = 'No schedule set';
    let cls = 'fw-semibold text-muted';
    if (v) {
      try {
        text = cronstrue.toString(v, { use24HourTimeFormat: true, verbose: false });
        cls = 'fw-semibold text-info';
      } catch {
        text = 'Invalid cron expression';
        cls = 'fw-semibold text-danger';
      }
    }
    cronHuman.className = cls;
    cronHuman.innerHTML = `<i class="bi bi-clock me-1"></i>${text}`;
  }
  cronInput?.addEventListener('input', updateCronHuman);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const res = await fetch('/api/settings/general', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        backupMode: fd.get('backupMode'),
        cronSchedule: fd.get('cronSchedule'),
      }),
    });
    const j = await res.json().catch(() => ({}));
    if (res.ok) {
      toast('Settings saved.' + (j.note ? ' ' + j.note : ''), 'success');
    } else {
      toast(j.error || 'Failed to save', 'danger');
    }
  });

</script>
