---
import Layout from '../../layouts/Layout.astro';
import { isMasterKeyConfigured } from '../../lib/secrets.js';
import { mustChangePassword } from '../../lib/auth.js';

const masterKeyOk = isMasterKeyConfigured();
const needsPasswordChange = mustChangePassword();

const tiles = [
  { href: '/settings/general', icon: 'bi-sliders', title: 'General', desc: 'Backup mode, cron schedule, manual trigger.', color: 'primary' },
  { href: '/settings/providers', icon: 'bi-key', title: 'Providers', desc: 'GitHub, Azure DevOps & GitLab PAT tokens, expirations, auto-discovery, test connections.', color: 'info' },
  { href: '/settings/repos', icon: 'bi-list-ul', title: 'Repositories list', desc: 'Add or remove URLs in repos.txt.', color: 'success' },
  { href: '/settings/smtp', icon: 'bi-envelope', title: 'SMTP / Notifications', desc: 'Email setup with a test-send button.', color: 'warning' },
  { href: '/settings/account', icon: 'bi-person-badge', title: 'Account', desc: 'Change your username and password.', color: 'secondary' },
];
---
<Layout
  title="GitEcho — Settings"
  active="settings"
  settingsActive="index"
  pageTitle="Settings"
  breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Settings' }]}
>
  {!masterKeyOk && (
    <div class="alert alert-warning d-flex align-items-start" role="alert">
      <i class="bi bi-shield-exclamation me-2 fs-5"></i>
      <div>
        <strong>MASTER_KEY is not set.</strong>
        <div class="small">PAT and SMTP-password fields cannot be saved through the UI until you set the <code>MASTER_KEY</code> environment variable. Generate one with <code>openssl rand -hex 32</code>.</div>
      </div>
    </div>
  )}

  {needsPasswordChange && (
    <div class="alert alert-warning d-flex align-items-start" role="alert">
      <i class="bi bi-exclamation-triangle me-2 fs-5"></i>
      <div>
        <strong>You're still using the default password.</strong>
        <div class="small">Head to <a href="/settings/account">Account</a> and pick a new password before exposing this install to the network.</div>
      </div>
    </div>
  )}

  <div class="row">
    {tiles.map((t) => (
      <div class="col-12 col-sm-6 col-lg-4">
        <a href={t.href} class="card h-100 text-decoration-none text-reset shadow-sm setting-tile">
          <div class="card-body text-center">
            <div class={`display-5 mb-2 text-${t.color}`}><i class={`bi ${t.icon}`}></i></div>
            <h5 class="card-title">{t.title}</h5>
            <p class="card-text small text-secondary mb-0">{t.desc}</p>
          </div>
        </a>
      </div>
    ))}
  </div>

  <style>
    .setting-tile { transition: transform 0.15s ease, box-shadow 0.15s ease; }
    .setting-tile:hover { transform: translateY(-3px); box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1) !important; }
  </style>
</Layout>
