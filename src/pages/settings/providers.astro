---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { loadSettings } from '../../lib/settings.js';
import { getConfig } from '../../lib/config.js';

const settings = loadSettings();
const cfg = getConfig();
const ghStored = Boolean(cfg.github?.pat);
const adoStored = Boolean(cfg.azureDevOps?.pat);
const glStored = Boolean(cfg.gitlab?.pat);
const ghExpires = settings.github?.patExpires ?? cfg.github?.patExpires?.toISOString().slice(0, 10) ?? '';
const adoExpires = settings.azureDevOps?.patExpires ?? cfg.azureDevOps?.patExpires?.toISOString().slice(0, 10) ?? '';
const glExpires = settings.gitlab?.patExpires ?? cfg.gitlab?.patExpires?.toISOString().slice(0, 10) ?? '';
const adoOrg = settings.azureDevOps?.org ?? cfg.azureDevOps?.org ?? '';
const glHost = settings.gitlab?.host ?? cfg.gitlab?.host ?? '';

const ghAutoDiscover = settings.github?.autoDiscover ?? true;
const adoAutoDiscover = settings.azureDevOps?.autoDiscover ?? true;
const glAutoDiscover = settings.gitlab?.autoDiscover ?? true;
const ghAutoCleanup = settings.github?.autoCleanupReposTxt ?? true;
const adoAutoCleanup = settings.azureDevOps?.autoCleanupReposTxt ?? true;
const glAutoCleanup = settings.gitlab?.autoCleanupReposTxt ?? true;
const ghNotifyOnNew = settings.github?.notifyOnNewRepo ?? true;
const adoNotifyOnNew = settings.azureDevOps?.notifyOnNewRepo ?? true;
const glNotifyOnNew = settings.gitlab?.notifyOnNewRepo ?? true;

const ghFilters = settings.github?.filters ?? {};
const adoFilters = settings.azureDevOps?.filters ?? {};
const glFilters = settings.gitlab?.filters ?? {};
const ghAllow = (ghFilters.ownerAllowList ?? []).join(', ');
const ghDeny = (ghFilters.ownerDenyList ?? []).join(', ');
const ghVisibility = ghFilters.visibility ?? 'all';
const adoAllow = (adoFilters.ownerAllowList ?? []).join(', ');
const adoDeny = (adoFilters.ownerDenyList ?? []).join(', ');
const adoVisibility = adoFilters.visibility ?? 'all';
const glAllow = (glFilters.ownerAllowList ?? []).join(', ');
const glDeny = (glFilters.ownerDenyList ?? []).join(', ');
const glVisibility = glFilters.visibility ?? 'all';

const smtpConfigured = Boolean(cfg.smtp);

const providers = [
  {
    key: 'github',
    icon: 'bi-github',
    title: 'GitHub',
    color: 'dark',
    stored: ghStored,
    expires: ghExpires,
    autoDiscover: ghAutoDiscover,
    autoCleanup: ghAutoCleanup,
    notifyOnNew: ghNotifyOnNew,
    allow: ghAllow,
    deny: ghDeny,
    visibility: ghVisibility,
    placeholder: 'ghp_...',
  },
  {
    key: 'azureDevOps',
    icon: 'bi-microsoft',
    title: 'Azure DevOps',
    color: 'primary',
    stored: adoStored,
    expires: adoExpires,
    autoDiscover: adoAutoDiscover,
    autoCleanup: adoAutoCleanup,
    notifyOnNew: adoNotifyOnNew,
    allow: adoAllow,
    deny: adoDeny,
    visibility: adoVisibility,
    placeholder: 'pat...',
    org: adoOrg,
  },
  {
    key: 'gitlab',
    icon: 'bi-gitlab',
    title: 'GitLab',
    color: 'warning',
    stored: glStored,
    expires: glExpires,
    autoDiscover: glAutoDiscover,
    autoCleanup: glAutoCleanup,
    notifyOnNew: glNotifyOnNew,
    allow: glAllow,
    deny: glDeny,
    visibility: glVisibility,
    placeholder: 'glpat-...',
    host: glHost,
  },
];
---
<Layout
  title="GitEcho — Settings · Providers"
  active="settings"
  settingsActive="providers"
  pageTitle="Providers"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Settings', href: '/settings' },
    { label: 'Providers' },
  ]}
>
  <ul class="nav nav-tabs mb-3" id="provider-tabs" role="tablist">
    {providers.map((p, i) => (
      <li class="nav-item" role="presentation">
        <button
          class={`nav-link ${i === 0 ? 'active' : ''}`}
          id={`tab-${p.key}`}
          data-bs-toggle="tab"
          data-bs-target={`#pane-${p.key}`}
          type="button"
          role="tab"
        >
          <i class={`bi ${p.icon} me-1`}></i>{p.title}
          {p.stored && <span class="badge text-bg-success ms-2">configured</span>}
        </button>
      </li>
    ))}
  </ul>

  <div class="tab-content">
    {providers.map((p, i) => (
      <div class={`tab-pane fade ${i === 0 ? 'show active' : ''}`} id={`pane-${p.key}`} role="tabpanel">
        <Card>
          {p.key === 'github' && (
            <div class="alert alert-info d-flex align-items-start gap-2 mb-3" role="alert">
              <i class="bi bi-info-circle-fill mt-1"></i>
              <div class="small">
                <strong>Required PAT scopes (GitHub)</strong>
                <ul class="mb-1 ps-3">
                  <li><strong>Classic PAT:</strong> <code>repo</code> (full — needed to clone private repos) and <code>read:org</code> (to list org-owned repos via <code>gh repo list</code>).</li>
                  <li><strong>Fine-grained PAT:</strong> Repository permissions → <em>Contents: Read</em> and <em>Metadata: Read</em>. Grant access to <strong>all repositories</strong> (or all in the target org) you want backed up — a fine-grained PAT only sees repos it was explicitly granted access to.</li>
                </ul>
                Create one at <a href="https://github.com/settings/tokens" target="_blank" rel="noopener">github.com/settings/tokens</a>.
                <div class="mt-2">
                  <strong>Accessing repos across multiple users / organizations</strong>
                  <ul class="mb-0 ps-3">
                    <li>A single <strong>classic PAT</strong> with <code>repo</code> + <code>read:org</code> sees every private repo your GitHub account has access to — your own repos, repos in orgs you belong to, and repos in other users' accounts where you're a collaborator.</li>
                    <li>If an org enforces <strong>SAML SSO</strong>, open the token on <a href="https://github.com/settings/tokens" target="_blank" rel="noopener">github.com/settings/tokens</a> and click <em>Configure SSO</em> → <em>Authorize</em> for each org. Without this, that org's repos stay invisible to the PAT even though you personally have access.</li>
                    <li><strong>Fine-grained PATs</strong> are scoped to a single resource owner (your user <em>or</em> one org) and don't support cross-account collaborator access — use a classic PAT if you need to back up repos from multiple owners.</li>
                  </ul>
                </div>
              </div>
            </div>
          )}
          {p.key === 'azureDevOps' && (
            <div class="alert alert-info d-flex align-items-start gap-2 mb-3" role="alert">
              <i class="bi bi-info-circle-fill mt-1"></i>
              <div class="small">
                <strong>Required PAT scopes (Azure DevOps)</strong>
                <ul class="mb-1 ps-3">
                  <li><strong>Code</strong> → <em>Read</em> (clone + list repos per project)</li>
                  <li><strong>Project and Team</strong> → <em>Read</em> (list all projects in the org)</li>
                </ul>
                Set <strong>Organization</strong> to <em>All accessible organizations</em> (or the specific one) when creating the PAT.
                Create one at <code>https://dev.azure.com/&lt;your-org&gt;/_usersSettings/tokens</code>.
                <div class="mt-2">
                  <strong>Discovery works but shows fewer repos than expected?</strong>
                  Test only calls <code>project list</code>; Discover additionally calls <code>repos list</code> per project.
                  If the PAT is missing <em>Code: Read</em> on some projects, those projects return no repos.
                </div>
                <div class="mt-2">
                  <strong>Accessing repos across multiple organizations</strong>
                  <ul class="mb-0 ps-3">
                    <li>Azure DevOps PATs are <strong>scoped to one organization at creation time</strong>. On the token page, set <em>Organization</em> to <em>All accessible organizations</em> to issue a PAT that works against every org your identity is a member of (same Entra ID / Microsoft account).</li>
                    <li>This field above (<em>Organization name</em>) still targets a single org for discovery — GitEcho iterates projects inside it. To back up repos from <strong>additional orgs</strong>, list them in <code>repos.txt</code> with their full <code>https://dev.azure.com/&lt;other-org&gt;/&lt;project&gt;/_git/&lt;repo&gt;</code> URL; the same PAT will authenticate as long as it was issued with <em>All accessible organizations</em>.</li>
                    <li>If the orgs live in <strong>different Entra tenants</strong> or under different Microsoft accounts, a single PAT can't span them — create one PAT per tenant and run separate GitEcho instances, or use each org's URL with its own credentials.</li>
                  </ul>
                </div>
              </div>
            </div>
          )}
          {p.key === 'gitlab' && (
            <div class="alert alert-info d-flex align-items-start gap-2 mb-3" role="alert">
              <i class="bi bi-info-circle-fill mt-1"></i>
              <div class="small">
                <strong>Required PAT scopes (GitLab)</strong>
                <ul class="mb-1 ps-3">
                  <li><code>read_api</code> (list projects you are a member of)</li>
                  <li><code>read_repository</code> (clone repositories over HTTPS)</li>
                </ul>
                Create one at <a href="https://gitlab.com/-/user_settings/personal_access_tokens" target="_blank" rel="noopener">gitlab.com/-/user_settings/personal_access_tokens</a>.
                GitLab PATs can be created without an expiration date — if yours does not expire, simply leave the expiry field empty or set a far-future date.
                <div class="mt-2">
                  <strong>Self-hosted GitLab</strong>
                  <ul class="mb-0 ps-3">
                    <li>Set <em>Host</em> below (e.g. <code>gitlab.example.com</code>). Discovery, cloning, and URL classification in <code>repos.txt</code> will all target that host.</li>
                    <li>Only repos whose URL lives on the configured host are treated as GitLab URLs; gitlab.com URLs become unclassified when a self-hosted host is set.</li>
                  </ul>
                </div>
                <div class="mt-2">
                  <strong>Nested groups</strong>
                  URLs like <code>https://gitlab.com/group/subgroup/repo</code> are fully supported — the <em>owner</em> column shows the full group path, and discovery walks every project the PAT is a member of.
                </div>
              </div>
            </div>
          )}
          <form class="provider-form row g-3" data-provider={p.key}>
            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Personal Access Token</label>
              <div class="input-group">
                <input type="password" name="pat" autocomplete="off" placeholder={p.stored ? '(stored — leave blank to keep)' : p.placeholder} class="form-control" />
                <button type="button" class="btn btn-outline-secondary" data-toggle-pass><i class="bi bi-eye"></i></button>
              </div>
            </div>
            <div class="col-12 col-md-3">
              <label class="form-label fw-semibold">Expires</label>
              <input type="date" name="patExpires" value={p.expires} class="form-control" />
            </div>
            {p.key === 'azureDevOps' && (
              <div class="col-12 col-md-3">
                <label class="form-label fw-semibold">Organization name</label>
                <input type="text" name="org" value={p.org} placeholder="myorg" class="form-control" />
                <div class="form-text small">
                  Just the name from <code>dev.azure.com/<strong>myorg</strong></code> (no URL, no slashes).
                </div>
              </div>
            )}
            {p.key === 'gitlab' && (
              <div class="col-12 col-md-3">
                <label class="form-label fw-semibold">Host</label>
                <input type="text" name="host" value={p.host} placeholder="gitlab.com" class="form-control" />
                <div class="form-text small">
                  Leave blank for SaaS. For self-hosted, use the hostname only (e.g. <code>gitlab.example.com</code>).
                </div>
              </div>
            )}

            <div class="col-12 col-lg-6">
              <fieldset class="border rounded p-3 h-100">
                <legend class="float-none w-auto px-2 fs-6 fw-semibold"><i class="bi bi-search me-1"></i>Discovery</legend>
                <div class="form-check form-switch mb-2">
                  <input class="form-check-input" type="checkbox" name="autoDiscover" id={`autoDiscover-${p.key}`} checked={p.autoDiscover} />
                  <label class="form-check-label" for={`autoDiscover-${p.key}`}>Auto-discover all repos visible to this PAT</label>
                </div>
                <div class="form-check form-switch mb-2">
                  <input class="form-check-input" type="checkbox" name="autoCleanupReposTxt" id={`autoCleanup-${p.key}`} checked={p.autoCleanup} />
                  <label class="form-check-label" for={`autoCleanup-${p.key}`}>Auto-clean <code>repos.txt</code> after discovery</label>
                  <div class="form-text small">
                    Removes URLs from <code>repos.txt</code> that are already
                    covered by auto-discovery, so the file stays focused on
                    <em>extras</em> (repos discovery can't see). Recommended.
                  </div>
                </div>
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" name="notifyOnNewRepo" id={`notifyOnNew-${p.key}`} checked={p.notifyOnNew} disabled={!smtpConfigured} />
                  <label class="form-check-label" for={`notifyOnNew-${p.key}`}>
                    Email when new repos are discovered
                    {!smtpConfigured && <span class="text-secondary small ms-1">(requires SMTP)</span>}
                  </label>
                </div>
              </fieldset>
            </div>

            <div class="col-12 col-lg-6">
              <fieldset class="border rounded p-3 h-100">
                <legend class="float-none w-auto px-2 fs-6 fw-semibold"><i class="bi bi-funnel me-1"></i>Filters</legend>
                <div class="mb-2">
                  <label class="form-label small mb-1">Owner allow-list (comma-separated)</label>
                  <input type="text" name="ownerAllowList" value={p.allow} placeholder="e.g. octocat, my-org" class="form-control form-control-sm" />
                </div>
                <div class="mb-2">
                  <label class="form-label small mb-1">Owner deny-list</label>
                  <input type="text" name="ownerDenyList" value={p.deny} placeholder="e.g. some-noisy-org" class="form-control form-control-sm" />
                </div>
                <div>
                  <label class="form-label small mb-1">Visibility</label>
                  <select name="visibility" class="form-select form-select-sm">
                    <option value="all" selected={p.visibility === 'all'}>All</option>
                    <option value="public" selected={p.visibility === 'public'}>Public only</option>
                    <option value="private" selected={p.visibility === 'private'}>Private only</option>
                  </select>
                </div>
              </fieldset>
            </div>

            <div class="col-12 d-flex gap-2 flex-wrap">
              <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button>
              <button type="button" class="btn btn-outline-primary" data-action="test"><i class="bi bi-plug me-1"></i>Test connection</button>
              <button type="button" class="btn btn-outline-secondary" data-action="discover"><i class="bi bi-search me-1"></i>Discover now</button>
              {p.stored && <button type="button" class="btn btn-outline-danger ms-auto" data-action="clear"><i class="bi bi-trash me-1"></i>Remove stored PAT</button>}
            </div>
          </form>
        </Card>
      </div>
    ))}
  </div>
</Layout>

<script>
  import { toast } from '../../scripts/toasts.ts';

  function parseList(value: FormDataEntryValue | null): string[] {
    return String(value || '')
      .split(',')
      .map((s) => s.trim())
      .filter(Boolean);
  }

  document.querySelectorAll<HTMLButtonElement>('[data-toggle-pass]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const input = btn.parentElement?.querySelector<HTMLInputElement>('input[name="pat"]');
      if (!input) return;
      input.type = input.type === 'password' ? 'text' : 'password';
      btn.querySelector('i')!.className = input.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
    });
  });

  document.querySelectorAll<HTMLFormElement>('.provider-form').forEach((form) => {
    const provider = form.getAttribute('data-provider')!;

    function payload() {
      const fd = new FormData(form);
      const out: Record<string, unknown> = {};
      const pat = fd.get('pat');
      if (pat) out.pat = pat;
      const exp = fd.get('patExpires');
      if (exp !== null) out.patExpires = exp;
      out.autoDiscover = (form.querySelector('input[name="autoDiscover"]') as HTMLInputElement).checked;
      out.autoCleanupReposTxt = (form.querySelector('input[name="autoCleanupReposTxt"]') as HTMLInputElement).checked;
      out.notifyOnNewRepo = (form.querySelector('input[name="notifyOnNewRepo"]') as HTMLInputElement).checked;
      out.filters = {
        ownerAllowList: parseList(fd.get('ownerAllowList')),
        ownerDenyList: parseList(fd.get('ownerDenyList')),
        visibility: fd.get('visibility') || 'all',
      };
      if (provider === 'azureDevOps') {
        const org = fd.get('org');
        if (org !== null) out.org = org;
      }
      if (provider === 'gitlab') {
        const host = fd.get('host');
        if (host !== null) out.host = host;
      }
      return out;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const body = { [provider]: payload() };
      const res = await fetch('/api/settings/providers', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const j = await res.json().catch(() => ({}));
      if (res.ok) {
        toast(j.discoveryStarted ? 'Saved. Discovery running in background…' : 'Saved.', 'success');
        setTimeout(() => location.reload(), 700);
      } else {
        toast(j.error || 'Failed to save', 'danger');
      }
    });

    form.querySelector<HTMLButtonElement>('[data-action="test"]')?.addEventListener('click', async () => {
      toast('Testing connection…', 'info');
      const fd = new FormData(form);
      const body: Record<string, unknown> = {};
      const pat = fd.get('pat');
      if (pat) body.pat = pat;
      if (provider === 'azureDevOps') {
        const org = fd.get('org');
        if (org) body.org = org;
      }
      if (provider === 'gitlab') {
        const host = fd.get('host');
        if (host) body.host = host;
      }
      const endpoint =
        provider === 'github'
          ? '/api/test/github'
          : provider === 'gitlab'
            ? '/api/test/gitlab'
            : '/api/test/azuredevops';
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const j = await res.json().catch(() => ({}));
      toast(j.message || j.error || (res.ok ? 'OK' : 'Failed'), res.ok ? 'success' : 'danger', 7000);
    });

    form.querySelector<HTMLButtonElement>('[data-action="discover"]')?.addEventListener('click', async () => {
      toast('Discovering…', 'info');
      const res = await fetch('/api/settings/providers/discover', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ provider }),
      });
      const j = await res.json().catch(() => ({}));
      if (res.ok && Array.isArray(j.providers) && j.providers.length > 0) {
        const p = j.providers[0];
        if (p.authenticated) {
          toast(
            `Found ${p.newlyDiscovered} new of ${p.total} (filtered out ${p.filteredOut}${p.appendedToReposTxt ? `, appended ${p.appendedToReposTxt}` : ''})`,
            'success',
            7000,
          );
        } else {
          toast('Authentication failed', 'danger');
        }
      } else {
        toast(j.error || 'Discovery failed', 'danger');
      }
    });

    form.querySelector<HTMLButtonElement>('[data-action="clear"]')?.addEventListener('click', async () => {
      if (!confirm('Remove the stored PAT for ' + provider + '?')) return;
      const res = await fetch('/api/settings/providers', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ [provider]: { clear: true } }),
      });
      if (res.ok) {
        toast('Stored PAT removed', 'success');
        setTimeout(() => location.reload(), 400);
      } else {
        toast('Failed to remove', 'danger');
      }
    });
  });
</script>
