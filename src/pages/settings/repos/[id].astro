---
// Per-repository detail page.
//
// Shows the canonical DB row (URL, provider, last sync status) with
// editable user notes and a "skip future backups" toggle. Below that:
// the last 20 backup attempts for this repo, joined with their run.
//
// Note: the backup engine does NOT overwrite last_sync_status when a
// repo is skipped — the status card here therefore keeps showing the
// last real attempt, which is the desired behaviour.

import Layout from '../../../layouts/Layout.astro';
import Card from '../../../components/Card.astro';
import {
  getRepositoryWithHistory,
  REPOSITORY_NOTES_MAX_LENGTH,
  type RepositoryBackupHistoryEntry,
  type Repository,
} from '../../../lib/database.js';
import { inspectBackupLock } from '../../../lib/backup-lock.js';

const { id: rawId } = Astro.params;
const id = rawId ? Number.parseInt(rawId, 10) : NaN;

let repo: Repository | null = null;
let history: RepositoryBackupHistoryEntry[] = [];
let loadError: string | null = null;

if (!Number.isFinite(id) || id <= 0) {
  loadError = `Invalid repository id: ${rawId}`;
} else {
  try {
    const result = getRepositoryWithHistory(id);
    if (!result) {
      loadError = `Repository #${id} not found.`;
    } else {
      repo = result.repo;
      history = result.history;
    }
  } catch (err) {
    loadError = (err as Error).message;
  }
}

function statusBadge(status: string | null): { cls: string; label: string } {
  switch (status) {
    case 'success':
      return { cls: 'text-bg-success', label: 'success' };
    case 'failed':
      return { cls: 'text-bg-danger', label: 'failed' };
    case 'unavailable':
      return { cls: 'text-bg-warning', label: 'unavailable' };
    case 'skipped':
      return { cls: 'text-bg-secondary', label: 'skipped' };
    case 'pending':
      return { cls: 'text-bg-info', label: 'pending' };
    case null:
    case undefined:
      return { cls: 'text-bg-secondary', label: 'never' };
    default:
      return { cls: 'text-bg-secondary', label: status ?? 'unknown' };
  }
}

const pageTitle = repo ? `${repo.owner} / ${repo.name}` : 'Repository';
const isSkipped = repo?.skip_backup === 1;
const isTracing = repo?.debug_trace === 1;
const activeLock = inspectBackupLock();
const backupRunning = activeLock !== undefined;
---
<Layout
  title={`GitEcho — ${pageTitle}`}
  active="settings"
  settingsActive="repos"
  pageTitle={pageTitle}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Settings', href: '/settings' },
    { label: 'Repositories', href: '/settings/repos' },
    { label: repo ? `#${repo.id}` : 'Detail' },
  ]}
>
  {loadError && (
    <div class="alert alert-danger">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>{loadError}
    </div>
  )}

  {repo && (
    <>
      <Card title="Overview" icon="bi-info-circle">
        <dl class="row mb-0 small">
          <dt class="col-sm-3">Provider</dt>
          <dd class="col-sm-9">
            {repo.provider === 'github'
              ? <span class="badge text-bg-dark"><i class="bi bi-github me-1"></i>GitHub</span>
              : repo.provider === 'azuredevops'
                ? <span class="badge text-bg-primary"><i class="bi bi-microsoft me-1"></i>Azure DevOps</span>
                : repo.provider === 'gitlab'
                  ? <span class="badge text-bg-warning"><i class="bi bi-gitlab me-1"></i>GitLab</span>
                  : <span class="badge text-bg-secondary">{repo.provider}</span>}
          </dd>

          <dt class="col-sm-3">Owner / Project</dt>
          <dd class="col-sm-9"><code>{repo.owner}</code></dd>

          <dt class="col-sm-3">Name</dt>
          <dd class="col-sm-9"><code>{repo.name}</code></dd>

          <dt class="col-sm-3">URL</dt>
          <dd class="col-sm-9">
            <a href={repo.url} target="_blank" rel="noopener noreferrer">{repo.url}</a>
          </dd>

          <dt class="col-sm-3">Last sync status</dt>
          <dd class="col-sm-9">
            {(() => { const b = statusBadge(repo.last_sync_status); return <span class={`badge ${b.cls}`}>{b.label}</span>; })()}
            {isSkipped && (
              <span class="badge text-bg-secondary ms-2"><i class="bi bi-pause-circle me-1"></i>excluded from backup</span>
            )}
          </dd>

          <dt class="col-sm-3">Last sync at</dt>
          <dd class="col-sm-9">{repo.last_sync_at ?? '—'}</dd>

          {repo.last_error && (
            <>
              <dt class="col-sm-3">Last error</dt>
              <dd class="col-sm-9"><code class="text-danger small">{repo.last_error}</code></dd>
            </>
          )}

          <dt class="col-sm-3">Checksum</dt>
          <dd class="col-sm-9"><code class="small">{repo.checksum ?? '—'}</code></dd>

          <dt class="col-sm-3">First seen</dt>
          <dd class="col-sm-9">{repo.created_at}</dd>

          <dt class="col-sm-3">Last updated</dt>
          <dd class="col-sm-9">{repo.updated_at}</dd>
        </dl>
      </Card>

      {!repo.archived && (
        <Card title="Manual run" icon="bi-play-circle">
          <p class="text-secondary small mb-2">
            Trigger a backup for <strong>this repository only</strong>. Uses the
            global backup lock, so it cannot run while a full cycle is in
            progress. The run appears in <a href="/runs">/runs</a> like any other.
          </p>
          {backupRunning && (
            <div class="alert alert-info small d-flex gap-2 py-2 mb-2" role="alert">
              <i class="bi bi-hourglass-split"></i>
              <div>
                A backup cycle is currently running{activeLock?.startedAt ? ` (started ${activeLock.startedAt})` : ''}.
                The button is disabled until it finishes.
              </div>
            </div>
          )}
          {isSkipped && !backupRunning && (
            <div class="alert alert-warning small d-flex gap-2 py-2 mb-2" role="alert">
              <i class="bi bi-pause-circle"></i>
              <div>
                This repository is excluded from backups. Disable the skip
                toggle below to enable manual runs.
              </div>
            </div>
          )}
          <button
            type="button"
            class="btn btn-primary"
            id="run-repo-backup-btn"
            data-repo-id={repo.id}
            disabled={backupRunning || isSkipped}
            title={
              backupRunning
                ? 'Wait for the running backup to finish'
                : isSkipped
                  ? 'Repository is excluded — disable the skip toggle first'
                  : undefined
            }
          >
            <i class="bi bi-play-fill me-1"></i>Run backup for this repository
          </button>
          <span id="run-repo-backup-status" class="text-secondary small ms-2"></span>
        </Card>
      )}

      <Card title="Settings" icon="bi-gear">
        <div class="form-check form-switch mb-3">
          <input
            class="form-check-input"
            type="checkbox"
            id="skip-backup-toggle"
            data-repo-id={repo.id}
            checked={isSkipped}
          />
          <label class="form-check-label" for="skip-backup-toggle">
            <strong>Exclude from future backups</strong>
            <div class="text-secondary small">
              When on, the backup engine skips this repository entirely.
              History, notes, and the last known status are preserved.
              Re-enable at any time to resume.
            </div>
          </label>
        </div>

        <div class="form-check form-switch mb-3">
          <input
            class="form-check-input"
            type="checkbox"
            id="debug-trace-toggle"
            data-repo-id={repo.id}
            checked={isTracing}
          />
          <label class="form-check-label" for="debug-trace-toggle">
            <strong>Verbose git trace (debug)</strong>
            <div class="text-secondary small">
              Captures <code>GIT_TRACE</code>, <code>GIT_CURL_VERBOSE</code>,
              <code>GIT_TRACE_PACKET</code> and <code>GIT_TRACE_PERFORMANCE</code> on the next
              clone or fetch and writes the full output to a log file below.
              Only enable while diagnosing a specific transport problem &mdash; the
              logs are large and may contain protocol-level detail.
            </div>
          </label>
        </div>

        <div class="mb-2">
          <label for="notes-input" class="form-label mb-1">
            <strong>Notes</strong>
            <span class="text-secondary small ms-2">
              Max {REPOSITORY_NOTES_MAX_LENGTH} characters. Saved automatically on blur.
            </span>
          </label>
          <textarea
            id="notes-input"
            class="form-control"
            rows="5"
            maxlength={REPOSITORY_NOTES_MAX_LENGTH}
            data-repo-id={repo.id}
            placeholder="Free text — context, owner contact, why it's skipped, links to tickets..."
          >{repo.notes ?? ''}</textarea>
          <div class="d-flex justify-content-between align-items-center mt-1">
            <small class="text-secondary">
              <span id="notes-count">{(repo.notes ?? '').length}</span> / {REPOSITORY_NOTES_MAX_LENGTH}
            </small>
            <button type="button" id="notes-save-btn" class="btn btn-sm btn-primary">
              <i class="bi bi-save me-1"></i>Save notes
            </button>
          </div>
        </div>
      </Card>

      <Card title="Debug traces" icon="bi-bug">
        <p class="text-secondary small mb-2">
          Log files written while <em>Verbose git trace</em> was on. Newest first.
          Enable the toggle above, trigger a backup, then refresh this page.
        </p>
        <div id="debug-logs-list" data-repo-id={repo.id}>
          <p class="text-secondary small mb-0">Loading…</p>
        </div>
      </Card>

      <Card title={`Backup history (last ${history.length})`} icon="bi-clock-history">
        {history.length === 0 ? (
          <p class="text-secondary mb-0">No backup attempts recorded for this repository yet.</p>
        ) : (          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Run</th>
                  <th>Status</th>
                  <th>Started</th>
                  <th>Completed</th>
                  <th>Error</th>
                </tr>
              </thead>
              <tbody>
                {history.map((h) => {
                  const b = statusBadge(h.status);
                  return (
                    <tr>
                      <td><a href={`/runs/${h.run_id}`}>#{h.run_id}</a></td>
                      <td><span class={`badge ${b.cls}`}>{b.label}</span></td>
                      <td class="small text-secondary">{h.started_at ?? h.run_started_at}</td>
                      <td class="small text-secondary">{h.completed_at ?? '—'}</td>
                      <td class="small">
                        {h.error
                          ? <code class="text-danger">{h.error.length > 120 ? h.error.slice(0, 120) + '…' : h.error}</code>
                          : '—'}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </Card>

      <Card title="Danger zone" icon="bi-exclamation-octagon">
        <p class="text-secondary small mb-3">
          Archiving and deletion are destructive and <strong>cannot be undone</strong>.
          Re-enabling an archived repository does <em>not</em> restore its
          historical backups.
        </p>
        {backupRunning && (
          <div class="alert alert-info small d-flex gap-2 py-2 mb-3" role="alert">
            <i class="bi bi-hourglass-split"></i>
            <div>
              A backup cycle is currently running{activeLock?.startedAt ? ` (started ${activeLock.startedAt})` : ''}.
              Archive and delete are disabled until it finishes to avoid
              corrupting backup data. Reload the page once the run completes.
            </div>
          </div>
        )}
        <div class="d-grid gap-2 d-md-flex">
          {!repo.archived ? (
            <button
              type="button"
              class="btn btn-outline-warning"
              id="archive-btn"
              data-repo-name={repo.name}
              disabled={backupRunning}
              title={backupRunning ? 'Wait for the running backup to finish' : undefined}
            >
              <i class="bi bi-archive-fill me-1"></i>Archive repository
            </button>
          ) : (
            <span class="badge text-bg-warning align-self-center p-2">
              <i class="bi bi-archive-fill me-1"></i>Already archived{repo.archived_at ? ` on ${repo.archived_at}` : ''}
            </span>
          )}
          <button
            type="button"
            class="btn btn-outline-danger"
            id="delete-btn"
            data-repo-name={repo.name}
            disabled={backupRunning}
            title={backupRunning ? 'Wait for the running backup to finish' : undefined}
          >
            <i class="bi bi-trash-fill me-1"></i>Delete repository permanently
          </button>
        </div>
      </Card>
    </>
  )}
</Layout>

{repo && (
  <>
    <div class="modal fade" id="archiveRepoModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header bg-warning">
            <h5 class="modal-title"><i class="bi bi-archive-fill me-1"></i>Archive repository</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="alert alert-warning small mb-3">
              <i class="bi bi-exclamation-triangle-fill me-1"></i>
              <strong>This cannot be undone.</strong> Archiving will:
              <ul class="mb-0 mt-2">
                <li>Pack all existing backup files into a single ZIP under <code>_archived/</code>.</li>
                <li>Delete the original backup directory.</li>
                <li>Stop future sync and backup runs for this repository.</li>
                <li>Hide the repository from the active list.</li>
              </ul>
            </div>
            <p class="mb-2">To confirm, type the repository name:</p>
            <p class="mb-2"><code class="fs-6">{repo.name}</code></p>
            <input type="text" id="archive-confirm-input" class="form-control" placeholder={repo.name} autocomplete="off" />
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-warning" id="archive-confirm-btn" disabled>
              <i class="bi bi-archive-fill me-1"></i>Archive
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="deleteRepoModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content border-danger">
          <div class="modal-header bg-danger text-white">
            <h5 class="modal-title"><i class="bi bi-trash-fill me-1"></i>Delete repository permanently</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="alert alert-danger small mb-3">
              <i class="bi bi-exclamation-octagon-fill me-1"></i>
              <strong>This cannot be undone.</strong> Deletion will:
              <ul class="mb-0 mt-2">
                <li>Remove all backup files for this repository from disk.</li>
                <li>Delete any existing archive ZIP.</li>
                <li>Remove the database entry (historical run items remain but lose their repo reference).</li>
                <li>Add the URL to the provider blacklist so auto-discovery won't re-create the entry.</li>
              </ul>
            </div>
            <p class="mb-2">To confirm, type the repository name:</p>
            <p class="mb-2"><code class="fs-6">{repo.name}</code></p>
            <input type="text" id="delete-confirm-input" class="form-control" placeholder={repo.name} autocomplete="off" />
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-danger" id="delete-confirm-btn" disabled>
              <i class="bi bi-trash-fill me-1"></i>Delete permanently
            </button>
          </div>
        </div>
      </div>
    </div>
  </>
)}

<script>
  import { Modal } from 'bootstrap';

  // Client-side handlers for the skip toggle and notes textarea.
  // Both hit PATCH /api/repos/:id; success is signalled via the global
  // toast helper (see scripts/toasts.ts).
  const toastFn: (msg: string, variant?: string) => void =
    (window as unknown as { showToast?: (m: string, v?: string) => void }).showToast
      ?? ((m: string) => console.log(m));
  const skipToggle = document.getElementById('skip-backup-toggle') as HTMLInputElement | null;
  const notesInput = document.getElementById('notes-input') as HTMLTextAreaElement | null;
  const notesCount = document.getElementById('notes-count');
  const notesSaveBtn = document.getElementById('notes-save-btn') as HTMLButtonElement | null;
  const runRepoBackupBtn = document.getElementById('run-repo-backup-btn') as HTMLButtonElement | null;
  const runRepoBackupStatus = document.getElementById('run-repo-backup-status');

  async function patchRepo(id: string, body: Record<string, unknown>): Promise<boolean> {
    try {
      const res = await fetch(`/api/repos/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: res.statusText }));
        toastFn(`Save failed: ${err.error ?? res.statusText}`, 'danger');
        return false;
      }
      return true;
    } catch (e) {
      toastFn(`Save failed: ${(e as Error).message}`, 'danger');
      return false;
    }
  }

  if (skipToggle) {
    skipToggle.addEventListener('change', async () => {
      const id = skipToggle.dataset.repoId!;
      skipToggle.disabled = true;
      const ok = await patchRepo(id, { skipBackup: skipToggle.checked });
      skipToggle.disabled = false;
      if (ok) {
        toastFn(
          skipToggle.checked ? 'Repository excluded from future backups.' : 'Repository re-enabled.',
          'success',
        );
      } else {
        // Revert UI on failure.
        skipToggle.checked = !skipToggle.checked;
      }
    });
  }

  if (runRepoBackupBtn) {
    const id = runRepoBackupBtn.dataset.repoId!;
    const originalHtml = runRepoBackupBtn.innerHTML;

    const pollUntilDone = async (): Promise<void> => {
      // Poll the shared trigger GET endpoint every 2s. Resolves when
      // `running` flips back to false.
      while (true) {
        await new Promise((r) => setTimeout(r, 2000));
        try {
          const res = await fetch('/api/backup/trigger');
          const j = await res.json();
          if (!j.running) return;
        } catch {
          // Transient failures during polling are non-fatal; keep trying.
        }
      }
    };

    runRepoBackupBtn.addEventListener('click', async () => {
      runRepoBackupBtn.disabled = true;
      runRepoBackupBtn.innerHTML =
        '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Starting…';
      if (runRepoBackupStatus) runRepoBackupStatus.textContent = '';
      try {
        const res = await fetch(`/api/repos/${id}/backup`, { method: 'POST' });
        const j = await res.json().catch(() => ({}));
        if (!res.ok) {
          toastFn(j.error || `Failed to start: ${res.statusText}`, 'danger');
          runRepoBackupBtn.innerHTML = originalHtml;
          runRepoBackupBtn.disabled = false;
          return;
        }
        toastFn('Backup started for this repository.', 'success');
        runRepoBackupBtn.innerHTML =
          '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Running…';
        if (runRepoBackupStatus) runRepoBackupStatus.textContent = 'Waiting for completion…';
        await pollUntilDone();
        toastFn('Backup finished — reloading…', 'success');
        setTimeout(() => window.location.reload(), 600);
      } catch (e) {
        toastFn(`Network error: ${(e as Error).message}`, 'danger');
        runRepoBackupBtn.innerHTML = originalHtml;
        runRepoBackupBtn.disabled = false;
      }
    });
  }

  if (notesInput && notesCount) {
    notesInput.addEventListener('input', () => {
      notesCount.textContent = String(notesInput.value.length);
    });

    let lastSaved = notesInput.value;
    const saveNotes = async () => {
      if (notesInput.value === lastSaved) return;
      const id = notesInput.dataset.repoId!;
      const ok = await patchRepo(id, { notes: notesInput.value });
      if (ok) {
        lastSaved = notesInput.value;
        toastFn('Notes saved.', 'success');
      }
    };

    notesInput.addEventListener('blur', saveNotes);
    notesSaveBtn?.addEventListener('click', saveNotes);
  }

  const debugToggle = document.getElementById('debug-trace-toggle') as HTMLInputElement | null;
  if (debugToggle) {
    debugToggle.addEventListener('change', async () => {
      const id = debugToggle.dataset.repoId!;
      debugToggle.disabled = true;
      const ok = await patchRepo(id, { debugTrace: debugToggle.checked });
      debugToggle.disabled = false;
      if (ok) {
        toastFn(
          debugToggle.checked
            ? 'Verbose trace enabled — run a backup to capture a log.'
            : 'Verbose trace disabled.',
          'success',
        );
      } else {
        debugToggle.checked = !debugToggle.checked;
      }
    });
  }

  // Populate the debug-logs list for the repo.
  const debugLogsList = document.getElementById('debug-logs-list');
  if (debugLogsList) {
    const repoId = debugLogsList.dataset.repoId!;
    const formatSize = (bytes: number): string => {
      if (bytes < 1024) return `${bytes} B`;
      if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KiB`;
      return `${(bytes / (1024 * 1024)).toFixed(1)} MiB`;
    };
    const escapeHtml = (s: string): string =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!);

    void fetch(`/api/repos/${repoId}/debug-logs`)
      .then((r) => r.json())
      .then((data: { files?: Array<{ name: string; size: number; mtime: string }> }) => {
        const files = data.files ?? [];
        if (files.length === 0) {
          debugLogsList.innerHTML =
            '<p class="text-secondary small mb-0">No trace logs captured yet.</p>';
          return;
        }
        const rows = files
          .map(
            (f) =>
              `<tr>
                <td class="small"><code>${escapeHtml(f.name)}</code></td>
                <td class="small text-secondary">${escapeHtml(f.mtime)}</td>
                <td class="small text-secondary">${formatSize(f.size)}</td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-primary"
                     href="/api/repos/${repoId}/debug-logs?file=${encodeURIComponent(f.name)}"
                     download>
                    <i class="bi bi-download me-1"></i>Download
                  </a>
                </td>
              </tr>`,
          )
          .join('');
        debugLogsList.innerHTML =
          `<div class="table-responsive"><table class="table table-sm table-hover align-middle mb-0">
            <thead><tr><th>File</th><th>Captured</th><th>Size</th><th></th></tr></thead>
            <tbody>${rows}</tbody>
          </table></div>`;
      })
      .catch((e: Error) => {
        debugLogsList.innerHTML =
          `<p class="text-danger small mb-0">Failed to load: ${escapeHtml(e.message)}</p>`;
      });
  }

  // ── Archive / Delete destructive actions ─────────────────────────────
  const archiveBtn = document.getElementById('archive-btn') as HTMLButtonElement | null;
  const archiveModalEl = document.getElementById('archiveRepoModal');
  const archiveInput = document.getElementById('archive-confirm-input') as HTMLInputElement | null;
  const archiveConfirmBtn = document.getElementById('archive-confirm-btn') as HTMLButtonElement | null;

  const deleteBtn = document.getElementById('delete-btn') as HTMLButtonElement | null;
  const deleteModalEl = document.getElementById('deleteRepoModal');
  const deleteInput = document.getElementById('delete-confirm-input') as HTMLInputElement | null;
  const deleteConfirmBtn = document.getElementById('delete-confirm-btn') as HTMLButtonElement | null;

  if (archiveBtn && archiveModalEl && archiveInput && archiveConfirmBtn) {
    const expectedName = archiveBtn.dataset.repoName ?? '';
    const repoId = archiveBtn.closest('[data-repo-id]')?.getAttribute('data-repo-id')
      ?? (document.querySelector('[data-repo-id]') as HTMLElement | null)?.dataset.repoId
      ?? '';

    archiveInput.addEventListener('input', () => {
      archiveConfirmBtn.disabled = archiveInput.value !== expectedName;
    });

    archiveBtn.addEventListener('click', () => {
      archiveInput.value = '';
      archiveConfirmBtn.disabled = true;
      Modal.getOrCreateInstance(archiveModalEl).show();
    });    archiveConfirmBtn.addEventListener('click', async () => {
      if (archiveInput.value !== expectedName) return;
      archiveConfirmBtn.disabled = true;
      try {
        const res = await fetch(`/api/repos/${repoId}/archive`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ confirmName: archiveInput.value }),
        });
        if (res.ok) {
          toastFn('Repository archived.', 'success');
          setTimeout(() => { window.location.href = '/settings/repos/archived'; }, 400);
        } else {
          const j = await res.json().catch(() => ({}));
          if (res.status === 409) {
            toastFn('A backup cycle is currently running — please wait until it finishes.', 'danger');
          } else {
            toastFn(`Archive failed: ${j.error ?? res.statusText}`, 'danger');
          }
          archiveConfirmBtn.disabled = false;
        }
      } catch (e) {
        toastFn(`Archive failed: ${(e as Error).message}`, 'danger');
        archiveConfirmBtn.disabled = false;
      }
    });
  }

  if (deleteBtn && deleteModalEl && deleteInput && deleteConfirmBtn) {
    const expectedName = deleteBtn.dataset.repoName ?? '';
    const repoId = (document.querySelector('[data-repo-id]') as HTMLElement | null)?.dataset.repoId ?? '';

    deleteInput.addEventListener('input', () => {
      deleteConfirmBtn.disabled = deleteInput.value !== expectedName;
    });

    deleteBtn.addEventListener('click', () => {
      deleteInput.value = '';
      deleteConfirmBtn.disabled = true;
      Modal.getOrCreateInstance(deleteModalEl).show();
    });

    deleteConfirmBtn.addEventListener('click', async () => {
      if (deleteInput.value !== expectedName) return;
      deleteConfirmBtn.disabled = true;
      try {
        const res = await fetch(`/api/repos/${repoId}`, {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ confirmName: deleteInput.value }),
        });
        if (res.ok) {
          toastFn('Repository deleted.', 'success');
          setTimeout(() => { window.location.href = '/settings/repos'; }, 400);
        } else {
          const j = await res.json().catch(() => ({}));
          if (res.status === 409) {
            toastFn('A backup cycle is currently running — please wait until it finishes.', 'danger');
          } else {
            toastFn(`Delete failed: ${j.error ?? res.statusText}`, 'danger');
          }
          deleteConfirmBtn.disabled = false;
        }
      } catch (e) {
        toastFn(`Delete failed: ${(e as Error).message}`, 'danger');
        deleteConfirmBtn.disabled = false;
      }
    });
  }
</script>
