---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { loadSettings } from '../../lib/settings.js';
import { getConfig } from '../../lib/config.js';

const settings = loadSettings();
const cfg = getConfig();
const passStored = Boolean(cfg.smtp?.pass);
const s = {
  host: settings.smtp?.host ?? cfg.smtp?.host ?? '',
  port: settings.smtp?.port ?? cfg.smtp?.port ?? 587,
  user: settings.smtp?.user ?? cfg.smtp?.user ?? '',
  from: settings.smtp?.from ?? cfg.smtp?.from ?? '',
  to: settings.smtp?.to ?? cfg.smtp?.to ?? '',
  notifyOnSuccess: settings.notifyOnSuccess ?? cfg.notifyOnSuccess,
  patExpiryWarnDays: settings.patExpiryWarnDays ?? cfg.patExpiryWarnDays,
};
---
<Layout
  title="GitEcho — Settings · SMTP"
  active="settings"
  settingsActive="smtp"
  pageTitle="SMTP / Notifications"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Settings', href: '/settings' },
    { label: 'SMTP' },
  ]}
>
  <Card title="SMTP server" icon="bi-envelope-at">
    <form id="smtp-form" class="row g-3">
      <div class="col-12 col-md-8">
        <label class="form-label">Host</label>
        <input name="host" value={s.host} placeholder="smtp.example.com" class="form-control" />
      </div>
      <div class="col-12 col-md-4">
        <label class="form-label">Port</label>
        <input name="port" type="number" min="1" value={s.port} class="form-control" />
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label">Username</label>
        <input name="user" value={s.user} placeholder="alerts@example.com" class="form-control" />
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label">Password</label>
        <div class="input-group">
          <input name="pass" type="password" autocomplete="off" placeholder={passStored ? '(stored — leave blank to keep)' : ''} class="form-control" />
          <button type="button" class="btn btn-outline-secondary" data-toggle-pass><i class="bi bi-eye"></i></button>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label">From</label>
        <input name="from" value={s.from} placeholder="gitecho@example.com" class="form-control" />
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label">To</label>
        <input name="to" value={s.to} placeholder="admin@example.com" class="form-control" />
      </div>
      <div class="col-12 col-md-6">
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" id="notifyOnSuccess" name="notifyOnSuccess" checked={s.notifyOnSuccess} />
          <label class="form-check-label" for="notifyOnSuccess">Notify on successful backup runs</label>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label">PAT-expiry warn (days)</label>
        <input name="patExpiryWarnDays" type="number" min="0" value={s.patExpiryWarnDays} class="form-control" style="max-width:8rem;" />
      </div>
      <div class="col-12 d-flex gap-2 flex-wrap">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button>
        <button type="button" id="test-btn" class="btn btn-outline-primary"><i class="bi bi-send me-1"></i>Send test email</button>
        {passStored && <button type="button" id="clear-pass" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i>Remove stored password</button>}
      </div>
    </form>
  </Card>
</Layout>

<script>
  import { toast } from '../../scripts/toasts.ts';

  const form = document.getElementById('smtp-form') as HTMLFormElement | null;

  document.querySelectorAll<HTMLButtonElement>('[data-toggle-pass]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const input = btn.parentElement?.querySelector<HTMLInputElement>('input[name="pass"]');
      if (!input) return;
      input.type = input.type === 'password' ? 'text' : 'password';
      btn.querySelector('i')!.className = input.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
    });
  });

  function buildBody(extra: Record<string, unknown> = {}) {
    if (!form) return extra;
    const fd = new FormData(form);
    const body: Record<string, unknown> = { ...extra };
    body.host = fd.get('host') || '';
    body.port = Number(fd.get('port')) || 587;
    body.user = fd.get('user') || '';
    const pass = fd.get('pass');
    if (pass) body.pass = pass;
    body.from = fd.get('from') || '';
    body.to = fd.get('to') || '';
    body.notifyOnSuccess = (form.querySelector('[name="notifyOnSuccess"]') as HTMLInputElement).checked;
    body.patExpiryWarnDays = Number(fd.get('patExpiryWarnDays')) || 0;
    return body;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const res = await fetch('/api/settings/smtp', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(buildBody()),
    });
    const j = await res.json().catch(() => ({}));
    if (res.ok) {
      toast('SMTP settings saved', 'success');
      setTimeout(() => location.reload(), 500);
    } else {
      toast(j.error || 'Failed to save', 'danger');
    }
  });

  document.getElementById('test-btn')?.addEventListener('click', async () => {
    toast('Sending test email…', 'info');
    const res = await fetch('/api/test/smtp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(buildBody()),
    });
    const j = await res.json().catch(() => ({}));
    toast(j.message || j.error || (res.ok ? 'Sent' : 'Failed'), res.ok ? 'success' : 'danger');
  });

  document.getElementById('clear-pass')?.addEventListener('click', async () => {
    if (!confirm('Remove the stored SMTP password?')) return;
    const res = await fetch('/api/settings/smtp', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ clearPass: true }),
    });
    if (res.ok) {
      toast('Stored password removed', 'success');
      setTimeout(() => location.reload(), 400);
    }
  });
</script>
