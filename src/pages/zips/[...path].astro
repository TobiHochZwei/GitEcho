---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { loadConfig } from '../../lib/config.js';
import { initDatabase } from '../../lib/database.js';
import { readdirSync, statSync, existsSync } from 'node:fs';
import { join } from 'node:path';

let config: any;
try {
  config = loadConfig();
  initDatabase(config.dataDir);
} catch (e) {
  config = {
    backupsDir: process.env.BACKUPS_DIR ?? '/backups',
    dataDir: process.env.DATA_DIR ?? '/data',
  };
}

const pathSegments = Astro.params.path || '';
const parts = pathSegments.split('/');
const provider = parts[0] || '';
const owner = parts[1] || '';
const repoName = parts[2] || '';

const repoDir = join(config.backupsDir, provider, owner, repoName);
const option3ZipsDir = join(repoDir, 'zips');

let zipsDir: string | null = null;
let zipsRelative = '';
if (existsSync(option3ZipsDir)) {
  zipsDir = option3ZipsDir;
  zipsRelative = `${pathSegments}/zips`;
} else if (existsSync(repoDir)) {
  zipsDir = repoDir;
  zipsRelative = pathSegments;
}

let zips: Array<{ name: string; size: number; date: Date }> = [];
let error: string | null = null;

if (!zipsDir) {
  error = 'No ZIP archives found for this repository';
} else {
  const items = readdirSync(zipsDir);
  zips = items
    .filter((name) => name.endsWith('.zip'))
    .map((name) => {
      const stat = statSync(join(zipsDir!, name));
      return { name, size: stat.size, date: stat.mtime };
    })
    .sort((a, b) => b.date.getTime() - a.date.getTime());
}

const totalSize = zips.reduce((acc, z) => acc + z.size, 0);
function fmtMB(b: number): string { return `${(b / 1024 / 1024).toFixed(2)} MB`; }
---
<Layout
  title={`GitEcho — Archives ${owner}/${repoName}`}
  active="repos"
  pageTitle={`${owner}/${repoName} — ZIP Archives`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Repositories', href: '/repos' },
    { label: `${owner}/${repoName}` },
  ]}
>
  {error ? (
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>{error}</div>
  ) : zips.length === 0 ? (
    <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>No ZIP archives found yet. Run a backup first.</div>
  ) : (
    <Card title={`${zips.length} archive${zips.length === 1 ? '' : 's'} · ${fmtMB(totalSize)} total`} icon="bi-file-earmark-zip">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Archive</th>
              <th class="text-end" style="width:8rem;">Size</th>
              <th style="width:14rem;">Created</th>
              <th class="text-end" style="width:10rem;">Action</th>
            </tr>
          </thead>
          <tbody>
            {zips.map((zip) => (
              <tr>
                <td><i class="bi bi-file-earmark-zip me-2 text-secondary"></i><span class="font-monospace small">{zip.name}</span></td>
                <td class="text-end font-monospace small">{fmtMB(zip.size)}</td>
                <td class="small">{zip.date.toLocaleString()}</td>
                <td class="text-end">
                  <a href={`/api/download?path=${encodeURIComponent(`${zipsRelative}/${zip.name}`)}&file=true`} class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-download me-1"></i>Download
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </Card>
  )}
</Layout>
